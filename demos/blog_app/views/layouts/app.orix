<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>@{ title }</title>
  <link rel="stylesheet" href="/assets/app.css">
</head>
<body>
  <header class="bar">
    <strong>@{ title }</strong>
    @{ if current_user }
    <span class="muted">@ @{ current_user }</span>
    @{ end }
  </header>
  @{ if flash_notice }
  <div class="flash">@{ flash_notice }</div>
  @{ end }
  @{ if flash_error }
  <div class="flash err">@{ flash_error }</div>
  @{ end }
  <main class="wrap">
    @{ content |> raw }
  </main>
</body>
</html>
