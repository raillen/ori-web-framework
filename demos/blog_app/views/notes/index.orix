@{ layout "layouts/app" }
@{ assign title = "Notes" }
<section class="card">
  <h1>Notes</h1>
  <p><a href="/notes/new">New note</a></p>
  <ul>
  @{ for i, item in items }
    <li><a href="/notes/@{ i }">@{ item }</a></li>
  @{ end }
  @{ if items_empty }
    <li class="muted">No items yet.</li>
  @{ end }
  </ul>
</section>
@{ end }
