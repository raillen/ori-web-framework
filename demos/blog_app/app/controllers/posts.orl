module app.controllers.posts

import app.application = app
import web = web
import templates = tpl

public index(req: web.Request) -> web.ActionResult
    var d: tpl.Data = tpl.empty_data()
    tpl.set_value(d, "title", "Posts")
    return app.render("posts/index", req, d)
end

