<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>@{ title }</title>
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body>
  <div class="wrap">
    <header class="app-bar">
      <div>
        <p class="eyebrow">ori-templates · ori-web</p>
        <h1>Ori Notes</h1>
      </div>
      <span class="count">@{ notes_count } notes</span>
    </header>

    @{ if flash_notice }
    <div class="flash" role="status">@{ flash_notice }</div>
    @{ end }
    @{ if flash_error }
    <div class="flash error" role="alert">@{ flash_error }</div>
    @{ end }

    <main>
      @{ content |> raw }
    </main>

    <footer class="meta">
      Server-rendered with <code>ori-templates</code> · CSRF + session · demo product for Fly.io
    </footer>
  </div>
</body>
</html>
