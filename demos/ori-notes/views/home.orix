@{ layout "layouts/app" }
@{ assign title = "Ori Notes" }

<section class="card">
  <h2>New note</h2>
  <form class="row" method="post" action="/notes">
    <input type="hidden" name="csrf_token" value="@{ csrf_token }">
    <input type="text" name="text" placeholder="Write something readable…" required autocomplete="off" maxlength="500">
    <button type="submit">Save</button>
  </form>
</section>

<section class="card">
  <h2>Your notes</h2>
  @{ include "notes/rows" }
</section>

@{ end }
