@{ layout "layouts/app" }
@{ assign title = "Login · ori-web-demo-auth" }
<h1>Sign in</h1>
<p>Use <code>demo</code> / <code>demo</code>.</p>
<form method="post" action="/login">
  <input type="hidden" name="csrf_token" value="@{ csrf_token }">
  <label>User<br><input name="user" autocomplete="username"></label>
  <label>Password<br><input name="password" type="password" autocomplete="current-password"></label>
  <button type="submit">Login</button>
</form>
@{ end }
